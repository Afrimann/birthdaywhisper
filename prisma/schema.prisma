generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String           @id @default(cuid())
  clerkId       String           @unique
  email         String           @unique
  username      String           @unique
  displayName   String
  avatarUrl     String?
  birthdayMonth Int
  birthdayDay   Int
  timezone      String           @default("UTC")
  isPremium     Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  followers      BirthdayFollow[]        @relation("FollowedUser")
  following      BirthdayFollow[]        @relation("FollowingUser")
  groupCards     GroupCard[]
  messages       Message[]
  sentMessages   Message[]               @relation("SentMessages")
  wishlistItems  WishlistItem[]
  notifPrefs     NotificationPreference?
  notifications  Notification[]

  @@index([username])
  @@index([birthdayMonth, birthdayDay])
}

model Message {
  id                 String        @id @default(cuid())
  recipientId        String
  senderId           String?
  content            String
  senderName         String?
  isAnonymous        Boolean       @default(true)
  cardTheme          CardTheme     @default(CLASSIC)
  voiceUrl           String?
  birthdayYear       Int
  status             MessageStatus @default(PENDING)
  revealedAt         DateTime?
  reactionEmoji      String?
  isReported         Boolean       @default(false)
  reportReason       String?
  isHidden           Boolean       @default(false)
  targetBirthdayYear Int?
  groupCardId        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  groupCard          GroupCard?    @relation(fields: [groupCardId], references: [id])
  recipient          User          @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  sender             User?         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([recipientId, birthdayYear])
  @@index([recipientId, status])
}

model BirthdayFollow {
  id               String   @id @default(cuid())
  followerId       String
  followedId       String
  notifyDaysBefore Int      @default(3)
  createdAt        DateTime @default(now())
  followed         User     @relation("FollowedUser", fields: [followedId], references: [id], onDelete: Cascade)
  follower         User     @relation("FollowingUser", fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, followedId])
  @@index([followedId])
}

model WishlistItem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  url         String?
  priceRange  String?
  isPurchased Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GroupCard {
  id            String    @id @default(cuid())
  recipientId   String
  createdById   String?
  createdByName String?
  title         String?
  inviteToken   String    @unique @default(cuid())
  birthdayYear  Int
  isLocked      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  recipient     User      @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([recipientId, birthdayYear])
}

model SenderSession {
  id              String   @id @default(cuid())
  fingerprintHash String
  recipientId     String
  messageCount    Int      @default(0)
  lastSentAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([fingerprintHash, recipientId])
  @@index([fingerprintHash])
}

model ScheduledEmail {
  id             String    @id @default(cuid())
  recipientEmail String
  type           EmailType
  payload        Json
  sendAt         DateTime
  sentAt         DateTime?
  failed         Boolean   @default(false)
  createdAt      DateTime  @default(now())

  @@index([sendAt, sentAt])
}

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailOnBirthdayUnlock Boolean  @default(true)
  emailReminders        Boolean  @default(true)
  emailReactions        Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String       @id @default(cuid())
  userId    String
  type      NotifType
  payload   Json
  read      Boolean      @default(false)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

enum NotifType {
  REACTION_RECEIVED
}

enum MessageStatus {
  PENDING
  REVEALED
  HIDDEN
}

enum CardTheme {
  CLASSIC
  GOLDEN_HOUR
  MIDNIGHT_STARS
  BLOOM
  RETRO
  NEON
}

enum EmailType {
  BIRTHDAY_UNLOCK
  BIRTHDAY_REMINDER_SENDER
  REACTION_RECEIVED
  WELCOME
}
